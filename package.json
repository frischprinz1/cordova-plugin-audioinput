{
  "name": "cordova-plugin-audioinput",
  "version": "2.0.0",
  "description": "Audio input capture plugin for Cordova and Capacitor - real-time microphone access with streaming and file recording support",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/",
    "ios/",
    "dist/",
    "src/",
    "www/",
    "AudioInput.podspec",
    "index.d.ts",
    "plugin.xml"
  ],
  "cordova": {
    "id": "cordova-plugin-audioinput",
    "platforms": [
      "android",
      "ios",
      "browser"
    ]
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  },
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "cd ios && pod install --repo-update && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "npm run eslint && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "npm run eslint -- --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "eslint": "eslint . --ext ts",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\"",
    "swiftlint": "node-swiftlint",
    "docgen": "docgen --api AudioInputPlugin --output-readme README.md --output-json dist/docs.json",
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/docgen": "^0.2.2",
    "@capacitor/ios": "^6.0.0",
    "@ionic/eslint-config": "^0.3.0",
    "@ionic/prettier-config": "^1.0.1",
    "@ionic/swiftlint-config": "^1.1.2",
    "eslint": "^7.11.0",
    "prettier": "~2.3.0",
    "prettier-plugin-java": "~1.0.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.32.0",
    "swiftlint": "^1.0.1",
    "typescript": "~4.1.5"
  },
  "peerDependencies": {
    "@capacitor/core": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@capacitor/core": {
      "optional": true
    }
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edimuj/cordova-plugin-audioinput.git"
  },
  "keywords": [
    "ecosystem:cordova",
    "ecosystem:capacitor",
    "ecosystem:phonegap",
    "cordova-android",
    "cordova-ios",
    "capacitor",
    "capacitor-plugin",
    "cordova plugin",
    "ios",
    "android",
    "cordova",
    "web-audio-api",
    "web audio api",
    "web audio",
    "waapi",
    "microphone",
    "mic",
    "audio",
    "input",
    "source",
    "AudioNode",
    "phonegap",
    "real-time",
    "streaming",
    "pcm"
  ],
  "author": "Edin Mujkanovic",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/edimuj/cordova-plugin-audioinput/issues"
  },
  "homepage": "https://github.com/edimuj/cordova-plugin-audioinput#readme"
}
